{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 850,
  "height": 620,
  "background": "white",
  "title": {
    "text": "Tree Locations Across Melbourne",
    "subtitle": "Each dot represents one tree recorded in the City of Melbourne urban forest dataset",
    "fontSize": 20,
    "subtitleFontSize": 13,
    "anchor": "start"
  },
  "projection": {
  "type": "mercator",
  "center": [144.95, -37.81],
  "scale": 340000
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/6_advanced_examples/data/VIC_LOCALITY_POLYGON_SHP.json",
        "format": {
          "type": "topojson",
          "feature": "VIC_LOCALITY_POLYGON_SHP"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#e8ce88",
        "stroke": "white",
        "strokeWidth": 0.7
      }
    },
    {
      "data": {
        "url": "../data/trees-with-species-and-dimensions-urban-forest.csv"
      },
      
      "mark": {
        "type": "circle",
        "size": 3,
        "opacity": 0.45,
        "color": "#228f09"
      },
      "encoding": {
        "longitude": {
          "field": "Longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "Latitude",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "Common Name",
            "type": "nominal",
            "title": "Tree Name"
          },
          {
            "field": "Scientific Name",
            "type": "nominal",
            "title": "Scientific Name"
          },
          {
            "field": "Precinct",
            "type": "nominal",
            "title": "Precinct"
          },
          {
            "field": "Age Description",
            "type": "nominal",
            "title": "Age"
          },
          {
            "field": "Diameter Breast Height",
            "type": "quantitative",
            "title": "Diameter"
          },
          {
            "field": "Year Planted",
            "type": "quantitative",
            "title": "Year Planted"
          }
        ]
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/6_advanced_examples/data/VIC_LOCALITY_POLYGON_SHP.json",
        "format": {
          "type": "topojson",
          "feature": "VIC_LOCALITY_POLYGON_SHP"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": null,
        "stroke": "white",
        "strokeWidth": 0.8
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    }
  }
}