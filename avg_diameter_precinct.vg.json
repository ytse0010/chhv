{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 760,
  "height": 480,
  "background": "white",
  "title": {
    "text": "Average Tree Diameter by Precinct",
    "subtitle": "Larger average diameter suggests more mature tree populations in that precinct",
    "fontSize": 20,
    "subtitleFontSize": 13,
    "anchor": "start"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/ytse0010/chhv/refs/heads/main/trees-with-species-and-dimensions-urban-forest.csv"
  },
  "transform": [
    {
      "filter": "datum['Diameter Breast Height'] != null && datum['Diameter Breast Height'] > 0"
    }
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4
  },
  "encoding": {
    "y": {
      "field": "Precinct",
      "type": "nominal",
      "sort": "-x",
      "title": null,
      "axis": {
        "labelFontSize": 12,
        "titleFontSize": 13
      }
    },
    "x": {
      "aggregate": "mean",
      "field": "Diameter Breast Height",
      "type": "quantitative",
      "title": "Average Diameter Breast Height",
      "axis": {
        "labelFontSize": 12,
        "titleFontSize": 13
      }
    },
    "color": {
      "aggregate": "mean",
      "field": "Diameter Breast Height",
      "type": "quantitative",
      "scale": {
        "scheme": "greens"
      },
      "legend": {
        "title": "Avg Diameter"
      }
    },
    "tooltip": [
      {
        "field": "Precinct",
        "type": "nominal",
        "title": "Precinct"
      },
      {
        "aggregate": "mean",
        "field": "Diameter Breast Height",
        "type": "quantitative",
        "title": "Average Diameter",
        "format": ".1f"
      },
      {
        "aggregate": "count",
        "type": "quantitative",
        "title": "Number of Trees"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "grid": false
    }
  }
}
