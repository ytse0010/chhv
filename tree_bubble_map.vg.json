{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 850,
  "height": 620,
  "background": "white",
  "title": {
    "text": "Where Are Melbourne's Largest Trees?",
    "subtitle": "Only trees with diameter breast height between 80 and 250 are shown",
    "fontSize": 20,
    "subtitleFontSize": 13,
    "anchor": "start"
  },
  "projection": {
    "type": "mercator",
    "center": [144.95, -37.81],
    "scale": 340000
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/6_advanced_examples/data/VIC_LOCALITY_POLYGON_SHP.json",
        "format": {
          "type": "topojson",
          "feature": "VIC_LOCALITY_POLYGON_SHP"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#e8ce88",
        "stroke": "white",
        "strokeWidth": 0.7
      }
    },
    {
      "data": {
        "url": "../data/trees-with-species-and-dimensions-urban-forest.csv"
      },
      "transform": [
        {
          "filter": "datum['Diameter Breast Height'] >= 80 && datum['Diameter Breast Height'] <= 250"
        }
      ],
      "mark": {
        "type": "circle",
        "opacity": 0.55,
        "stroke": "#145a32",
        "strokeWidth": 0.3
      },
      "encoding": {
        "longitude": {
          "field": "Longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "Latitude",
          "type": "quantitative"
        },
        "size": {
          "field": "Diameter Breast Height",
          "type": "quantitative",
          "title": "Diameter",
          "scale": {
            "domain": [80, 250],
            "range": [20, 280]
          },
          "legend": {
            "title": "Diameter"
          }
        },
        "color": {
          "field": "Age Description",
          "type": "nominal",
          "title": "Age",
          "scale": {
            "domain": [
              "Young",
              "Semi-mature",
              "Mature",
              "Over-mature"
            ],
            "range": [
              "#b7e4a8",
              "#74c476",
              "#238b45",
              "#00441b"
            ]
          }
        },
        "tooltip": [
          {
            "field": "Common Name",
            "type": "nominal",
            "title": "Tree Name"
          },
          {
            "field": "Scientific Name",
            "type": "nominal",
            "title": "Scientific Name"
          },
          {
            "field": "Precinct",
            "type": "nominal",
            "title": "Precinct"
          },
          {
            "field": "Age Description",
            "type": "nominal",
            "title": "Age"
          },
          {
            "field": "Diameter Breast Height",
            "type": "quantitative",
            "title": "Diameter"
          },
          {
            "field": "Year Planted",
            "type": "quantitative",
            "title": "Year Planted"
          }
        ]
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/6_advanced_examples/data/VIC_LOCALITY_POLYGON_SHP.json",
        "format": {
          "type": "topojson",
          "feature": "VIC_LOCALITY_POLYGON_SHP"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": null,
        "stroke": "white",
        "strokeWidth": 0.8
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    }
  }
}